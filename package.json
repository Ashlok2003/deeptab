{
  "name": "deeptab",
  "displayName": "Deeptab",
  "description": "Context-aware AI coding assistant with intelligent completion, code explanation, and review capabilities.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Deeptab Configuration",
      "properties": {
        "deeptab.fireworksApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the Fireworks service. Required when using Fireworks as the provider."
        },
        "deeptab.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the Groq service. Required when using Groq as the provider."
        },
        "deeptab.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the OpenRouter service. Required when using OpenRouter as the provider."
        },
        "deeptab.openrouterModel": {
          "type": "string",
          "default": "poolside/laguna-xs.2:free",
          "description": "OpenRouter model to use for code completions."
        },
        "deeptab.model": {
          "type": "string",
          "default": "qwen/qwen3-32b",
          "description": "AI model for Groq/Fireworks providers."
        },
        "deeptab.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum number of tokens for AI responses."
        },
        "deeptab.temperature": {
          "type": "number",
          "default": 0.1,
          "description": "Temperature setting for AI creativity (0.0 - 1.0)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:integration",
    "pretest:unit": "npm run compile",
    "test:unit": "mocha 'out/test/unit/**/*.test.js'",
    "test:integration": "vscode-test",
    "coverage": "c8 --include 'out/core/**' --check-coverage --lines 90 mocha 'out/test/unit/**/*.test.js'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "c8": "^11.0.0",
    "eslint": "^9.39.3",
    "mocha": "^11.7.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
